          "type": "data",
          "data": {
            "text/html": "\n    <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px;\">\n      <div style=\"background:var(--color-background-secondary);border-radius:8px;padding:12px;text-align:center\">\n        <div style=\"font-size:11px;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:.05em\">Method</div>\n        <div style=\"font-size:18px;font-weight:500;color:var(--color-text-primary)\">SnapKV</div>\n      </div>\n      <div style=\"background:var(--color-background-secondary);border-radius:8px;padding:12px;text-align:center\">\n        <div style=\"font-size:11px;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:.05em\">Tokens kept</div>\n        <div style=\"font-size:18px;font-weight:500;color:#1D9E75\">21 / 72</div>\n      </div>\n      <div style=\"background:var(--color-background-secondary);border-radius:8px;padding:12px;text-align:center\">\n        <div style=\"font-size:11px;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:.05em\">Cache size</div>\n        <div style=\"font-size:18px;font-weight:500;color:#BA7517\">29%</div>\n      </div>\n    </div>\n    <div style=\"background:var(--color-background-secondary);border-radius:8px;padding:14px;line-height:1.9\">\n      <div style=\"font-size:11px;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:.05em;margin-bottom:8px\">\n        Token selection\n        &nbsp;\u00b7&nbsp;<span style=\"background:#9FE1CB;border:1px solid #1D9E75;border-radius:3px;padding:1px 6px;font-size:11px\">kept</span>\n        &nbsp;<span style=\"background:#AFA9EC;border:1px solid #534AB7;border-radius:3px;padding:1px 6px;font-size:11px\">obs. window</span>\n        &nbsp;<span style=\"background:#F5C4B3;border:1px solid #D85A30;border-radius:3px;padding:1px 6px;font-size:11px\">evicted</span>\n      </div>\n      <span title=\"evicted\" style=\"display:inline-block;margin:3px 2px;padding:3