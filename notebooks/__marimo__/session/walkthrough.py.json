      "outputs": [
        {
          "type": "data",
          "data": {
            "text/html": "\n    <div style=\"position:relative;width:100%;height:320px;\">\n    <canvas id=\"kvgrowth\" role=\"img\" aria-label=\"KV cache memory vs sequence length for different methods\">\n      Full cache grows from 4295MB at 1K tokens to 4295MB at 32K tokens.\n    </canvas></div>\n    <script src=\"https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js\"></script>\n    <script>\n    new Chart(document.getElementById('kvgrowth'),{\n      type:'bar',\n      data:{\n        labels:[\"8K\"],\n        datasets:[\n          {label:'Full cache', data:[4294.967296], backgroundColor:'#B4B2A9', borderWidth:0},\n          {label:'H2O (20%)',  data:[858.783744],  backgroundColor:'#BA7517', borderWidth:0},\n          {label:'StreamingLLM', data:[643.825664], backgroundColor:'#534AB7', borderWidth:0},\n          {label:'SnapKV (25%)', data:[1073.741824], backgroundColor:'#1D9E75', borderWidth:0},\n        ]\n      },\n      options:{\n        responsive:true, maintainAspectRatio:false,\n        plugins:{legend:{position:'top', labels:{boxWidth:12,font:{size:12}}}},\n        scales:{\n          x:{title:{display:true,text:'Sequence length'}},\n          y:{title:{display:true,text:'Memory (MB)'},beginAtZero:true}\n        }\n      }\n    });\n    </script>\n    "
          }
        }
      ],
      "console": []
