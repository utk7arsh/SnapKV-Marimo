diction (w=16)',\n            data:[0.018, 0.01, 0.0129, 0.0104, 0.018, 0.0081, 0.0787, 0.0098, 0.011, 0.0153, 0.0023, 0.0065, 0.0036, 0.0164, 0.0091, 0.0031, 0.0147, 0.0083, 0.0109, 0.0064, 0.0186, 0.0062, 0.0179, 0.0134, 0.0085, 0.0128, 0.0129, 0.0149, 0.0854, 0.0079, 0.0058, 0.007, 0.0175, 0.0188, 0.009, 0.0656, 0.0081, 0.0051, 0.0087, 0.004, 0.0084, 0.0086, 0.061, 0.0141, 0.0127, 0.0065, 0.0951, 0.0114, 0.0124, 0.0015, 0.0091, 0.0028, 0.0136, 0.0067, 0.0159, 0.0133, 0.0148, 0.0066, 0.0066, 0.0055, 0.0147, 0.0063, 0.0203, 0.0103],\n            borderColor:'#1D9E75', borderWidth:1.5, borderDash:[4,2],\n            pointRadius:0, fill:false, tension:0.3\n          }\n        ]\n      },\n      options:{\n        responsive:true, maintainAspectRatio:false,\n        plugins:{legend:{position:'top',labels:{boxWidth:12,font:{size:12}}}},\n        scales:{\n          x:{title:{display:true,text:'Token position'},ticks:{maxTicksLimit:16}},\n          y:{title:{display:true,text:'Attention score'},beginAtZero:true}\n        }\n      }\n    });\n    </script>\n    "
